#. Translators: The text of the donate dialog
#: addon\installTasks.py:31 addon\globalPlugins\nao\donate.py:34
#, python-brace-format
msgid ""
"{name} - free add-on for NVDA.\n"
"You can make a donation to our team for helping further development of this "
"add-on.\n"
"Do you want to make a donation now? For transaction you will be redirected "
"to the website of the developer."
msgstr ""
"{name} — безкоштовний додаток для NVDA.\n"
"Ви можете зробити пожертву нашій команді, щоб підтримати подальший розвиток "
"цього додатка.\n"
"Хочете зробити пожертву зараз? Для здійснення транзакції вас буде "
"перенаправлено на сайт розробника."

#. Translators: Message presented in input help mode.
#: addon\globalPlugins\nao\__init__.py:66
msgid "Recognizes the content of the selected image or PDF file"
msgstr "Розпізнає вміст вибраного зображення або PDF-файлу"

#. Translators: Message presented in input help mode.
#: addon\globalPlugins\nao\__init__.py:92
msgid "Take a full screen shot and recognize it"
msgstr "Зробити знімок усього екрана та розпізнати"

#. Translators: Message presented in input help mode.
#: addon\globalPlugins\nao\__init__.py:101
msgid "Take a screen shot of the current window and recognize it"
msgstr "Зробити знімок екрана поточного вікна та розпізнати"

#. Translators: A label for a shortcut to go to NAO website
#: addon\globalPlugins\nao\systray_menu.py:39
msgid "NAO web site"
msgstr "Веб-сайт NAO"

#. Translators: The label of a menu item to clear the cache
#: addon\globalPlugins\nao\systray_menu.py:51
msgid "Clear cache"
msgstr "Очистити кеш"

#. Translators: The title of the update dialog
#: addon\globalPlugins\nao\framework\generic\updates.py:28
#: addon\globalPlugins\nao\framework\generic\updates.py:370
#: addon\globalPlugins\nao\framework\generic\updates.py:383
#, python-brace-format
msgid "{name} Update"
msgstr "Оновлення {name}"

#. Translators: The message of the update dialog
#: addon\globalPlugins\nao\framework\generic\updates.py:35
msgid "is available"
msgstr "доступне"

#. Translators: The message of the update dialog
#: addon\globalPlugins\nao\framework\generic\updates.py:37
msgid "Do you want to download and install it?"
msgstr "Ви хочете завантажити та встановити?"

#. Translators: The title of the dialog used to move to a different page
#: addon\globalPlugins\nao\framework\ocr\ocr_document_dialog.py:21
msgid "Move to"
msgstr "Перейти до"

#. Translators: Dialog text presented when NVDA cannot save a document file.
#: addon\globalPlugins\nao\framework\ocr\ocr_document_dialog.py:338
#: addon\globalPlugins\nao\framework\ocr\ocr_document_dialog.py:345
#, python-format
msgid "Error saving file: %s"
msgstr "Помилка збереження файлу: %s"

#. Translators: Reported when unable to process a file for recognition.
#: addon\globalPlugins\nao\framework\ocr\ocr_helper.py:78
#: addon\globalPlugins\nao\framework\ocr\ocr_helper.py:273
msgid "Error, the file could not be processed"
msgstr "Помилка, не вдалося обробити файл"

#. Translators: Reported when the file format is not supported for recognition.
#: addon\globalPlugins\nao\framework\ocr\ocr_helper.py:103
#: addon\globalPlugins\nao\framework\ocr\ocr_helper.py:141
msgid "File not supported"
msgstr "Файл не підтримується"

#. Translators: Reported when the recognition starts.
#: addon\globalPlugins\nao\framework\ocr\ocr_helper.py:222
msgid "Process started"
msgstr "Процес розпочато"

#. Add-on summary, usually the user visible name of the addon.
#. Translators: Summary for this add-on
#. to be shown on installation and add-on information found in Add-ons Manager.
#: buildVars.py:23
msgid "Nao"
msgstr "Nao"

#. Add-on description
#. Translators: Long description to be shown for this add-on on add-on information from add-ons manager
#: buildVars.py:26
msgid ""
"Nao (NVDA Advanced OCR) is an addon that improves the standard OCR "
"capabilities that NVDA provides on modern Windows versions."
msgstr ""
"Nao (NVDA Advanced OCR) — це додаток, який розширює стандартні можливості "
"розпізнавання тексту, що надаються NVDA в сучасних версіях Windows."
